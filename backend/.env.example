# Обычно используется корневой .env в папке VOLNA.
# Этот файл нужен только если backend запускается отдельно из папки backend.
DJANGO_DEBUG=True
DJANGO_SECRET_KEY=change-me-local-dev-secret-key
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost
DJANGO_CSRF_TRUSTED_ORIGINS=http://127.0.0.1:8000,http://localhost:8000,http://127.0.0.1:5173,http://localhost:5173
DJANGO_CORS_ALLOWED_ORIGINS=http://127.0.0.1:5173,http://localhost:5173
DJANGO_ADMIN_URL=admin/
POSTGRES_DB=volna
POSTGRES_USER=volna
POSTGRES_PASSWORD=change-me-local-db-password
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
