# Frontend
# Для локального запуска через Vite proxy можно оставить пустым.
# Для Docker dev обычно удобно указать http://127.0.0.1:8000
VITE_API_BASE_URL=

# Django
DJANGO_DEBUG=True
DJANGO_SECRET_KEY=change-me-local-dev-secret-key
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost
DJANGO_CSRF_TRUSTED_ORIGINS=http://127.0.0.1:8000,http://localhost:8000,http://127.0.0.1:5173,http://localhost:5173
DJANGO_CORS_ALLOWED_ORIGINS=http://127.0.0.1:5173,http://localhost:5173
DJANGO_ADMIN_URL=admin/
DJANGO_TIME_ZONE=Europe/Moscow
DJANGO_SECURE_SSL_REDIRECT=False
DJANGO_SECURE_HSTS_SECONDS=0
DJANGO_SECURE_HSTS_INCLUDE_SUBDOMAINS=False
DJANGO_SECURE_HSTS_PRELOAD=False

# PostgreSQL
POSTGRES_DB=volna
POSTGRES_USER=volna
POSTGRES_PASSWORD=change-me-local-db-password
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
POSTGRES_CONN_MAX_AGE=60

# DRF throttling
DRF_ANON_THROTTLE_RATE=120/hour
DRF_REGISTRATION_THROTTLE_RATE=20/hour

# Sentry, optional
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_TRACES_SAMPLE_RATE=0.0

# Email, optional
DJANGO_EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
DJANGO_DEFAULT_FROM_EMAIL=no-reply@example.ru
